# Insertion Sort with User Input
numbers = input("Enter numbers separated by spaces: ").split()
arr = [int(x) for x in numbers]

for i in range(1, len(arr)):
    key = arr[i]
    j = i - 1
    while j >= 0 and arr[j] > key:
        arr[j + 1] = arr[j]
        j -= 1
    arr[j + 1] = key

print("Sorted:", arr)
